# ============================================================================
# STREAMWARD AI ASSISTANT - FRONTEND ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this to .env.local and fill in your actual values.

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-key

# Okta Authentication (Custom Authorization Server)
OKTA_CLIENT_ID=your-okta-client-id
OKTA_CLIENT_SECRET=your-okta-client-secret
OKTA_ISSUER=https://your-okta-domain.okta.com
NEXT_PUBLIC_OKTA_BASE_URL=https://your-okta-domain.okta.com
NEXT_PUBLIC_OKTA_CLIENT_ID=your-okta-client-id
NEXT_PUBLIC_OKTA_MAIN_SERVER_ID=your-custom-authorization-server-id

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
